{
  "name": "@utoolios/tools",
  "version": "0.0.0",
  "private": true,
  "description": "All tool plugins, one folder each (docs/06, docs/13). The registry is generated by scripts/generate-tools-registry.mjs — never hand-edited.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "gen": "node ../../scripts/generate-tools-registry.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@utoolios/core": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
