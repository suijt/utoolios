{
  "name": "utoolios",
  "version": "0.0.0",
  "private": true,
  "description": "UToolios — thousands of free online tools. One trusted platform.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "turbo run lint typecheck test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
